# Supabase — copy to .env.local and fill in. The first two are safe for the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Server-only Supabase secret key (Settings -> API -> Secret keys; the sb_secret_... value).
# Bypasses RLS. NEVER expose to the browser and NEVER commit. Used only in server code
# (the trade route, the equity-refresh cron).
SUPABASE_SECRET_KEY=sb_secret_xxx

# Secret guarding the leaderboard-refresh cron. Set the same value in Vercel; Vercel Cron
# sends it as the Authorization header. Any long random string.
CRON_SECRET=replace-with-a-long-random-string
